# ════════════════════════════════════════════════════════
#  RepoLens — Environment Variables
#  Copy this file:  cp .env.example .env
#  Then fill in your real values below.
# ════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# RECOMMENDED: GitHub Personal Access Token
# Without this: 60 req/hr rate limit (repo fetch may fail)
# With this:  5000 req/hr
#
# Create one at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only is enough)
# ─────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────
# OPTIONAL: Anthropic Claude API Key (fallback AI engine)
# Get yours at: https://console.anthropic.com/
# Only needed if Ollama is NOT running locally.
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────
# OPTIONAL: Ollama Configuration (primary AI engine)
# Install Ollama: https://ollama.com
# Then run:       ollama pull phi3
# ─────────────────────────────────────────────────────────
OLLAMA_MODEL=phi3

# ─────────────────────────────────────────────────────────
# OPTIONAL: Flask settings
# ─────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
